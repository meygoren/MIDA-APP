# HMAC secret used to sign session tokens and hash PINs. Set this to a
# long random string in production.
SESSION_SECRET=

# Bootstrap admin accounts, created automatically the first time the app
# runs against an empty database. Format: "pin:name:role1+role2" pairs,
# comma separated between people, "+" separated between roles for the same
# person. Roles: admin | sales | procurement | finance | aftersales.
# Example: BUILT_IN_PINS=1234:Mehmet:admin,5678:Wei:sales+finance
BUILT_IN_PINS=

# Upstash Redis (create a separate database/project from any other app).
KV_REST_API_URL=
KV_REST_API_TOKEN=
